<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="12dp"
    android:background="@drawable/widget_background"
    android:id="@+id/widget_root">

    <!-- Top row: Mode + Streak -->
    <LinearLayout
        android:id="@+id/widget_top_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_alignParentTop="true">

        <TextView
            android:id="@+id/widget_mode"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="FOCUS"
            android:textSize="10sp"
            android:textColor="#7c6fae"
            android:letterSpacing="0.15"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_streak"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔥 0"
            android:textSize="10sp"
            android:textColor="#a09080" />
    </LinearLayout>

    <!-- Timer display -->
    <TextView
        android:id="@+id/widget_timer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/widget_top_row"
        android:layout_above="@id/widget_progress_bar"
        android:gravity="center"
        android:text="25:00"
        android:textSize="42sp"
        android:textColor="#e8e6ef"
        android:fontFamily="sans-serif-thin"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="4dp" />

    <!-- Progress bar -->
    <ProgressBar
        android:id="@+id/widget_progress_bar"
        style="@android:style/Widget.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:layout_above="@id/widget_controls"
        android:layout_marginBottom="8dp"
        android:layout_marginLeft="4dp"
        android:layout_marginRight="4dp"
        android:max="100"
        android:progress="0"
        android:progressDrawable="@drawable/widget_progress"
        android:background="@drawable/widget_progress_bg" />

    <!-- Control buttons -->
    <LinearLayout
        android:id="@+id/widget_controls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_above="@id/widget_bottom_row"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="4dp">

        <ImageView
            android:id="@+id/widget_btn_reset"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:padding="8dp"
            android:src="@drawable/ic_reset"
            android:background="@drawable/widget_btn_bg"
            android:contentDescription="Reset" />

        <ImageView
            android:id="@+id/widget_btn_play"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:padding="8dp"
            android:layout_marginLeft="12dp"
            android:layout_marginRight="12dp"
            android:src="@drawable/ic_play"
            android:background="@drawable/widget_btn_primary"
            android:contentDescription="Start" />

        <ImageView
            android:id="@+id/widget_btn_skip"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:padding="8dp"
            android:src="@drawable/ic_skip"
            android:background="@drawable/widget_btn_bg"
            android:contentDescription="Skip" />
    </LinearLayout>

    <!-- Bottom row: Sessions today + status -->
    <LinearLayout
        android:id="@+id/widget_bottom_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/widget_sessions"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="0 sessions today"
            android:textSize="9sp"
            android:textColor="#4e4968" />

        <TextView
            android:id="@+id/widget_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ready"
            android:textSize="9sp"
            android:textColor="#4e4968" />
    </LinearLayout>

</RelativeLayout>
